{
  "name": "aurora",
  "version": "1.0.0",
  "description": "Aurora — Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "electron": "electron .",
    "build:client": "cd client && npm run build",
    "dist": "npm run build:client && electron-builder",
    "dist:linux": "npm run build:client && electron-builder --linux",
    "dist:win": "npm run build:client && electron-builder --win",
    "dist:mac": "npm run build:client && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aurora.messenger",
    "productName": "Aurora",
    "files": [
      "electron/**/*",
      "client/build/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "icon": "client/public/logo512.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "client/public/logo512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "client/public/logo512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": {
    "name": "kayano",
    "email": "azarskovap@gmail.com"
  }
}